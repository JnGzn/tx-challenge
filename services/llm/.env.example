HTTP_PORT=3000
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres-llm:5432/llm?schema=public
POSTGRES_PASSWORD=change-me
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=llm-service
KAFKA_GROUP_ID=llm-consumer
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
# Optional: sampling temperature for the LLM (0..2). Default 0.2
# LLM_TEMPERATURE=0.2
# Optional: max events loaded for account history summary. Default 25
# LLM_HISTORY_LIMIT=25
